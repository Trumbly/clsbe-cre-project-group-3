    {
      "SurveyID": "SV_CLSBECREGROUP03",
      "Element": "SQ",
      "PrimaryAttribute": "QID8",
      "SecondaryAttribute": "",
      "TertiaryAttribute": null,
      "Payload": {
        "QuestionText": "<p><strong>Imagine you are in the CLSBE cafeteria at lunchtime.</strong></p><p>To simulate a real cafeteria queue, please evaluate each meal option <strong>quickly</strong>. You will have a short countdown (<strong>8 seconds</strong>) next to each rating. Please don't overthink — trust your gut.</p><p>The scale runs from <strong>1 = Not at all appealing</strong> to <strong>7 = Extremely appealing</strong>.</p>",
        "DataExportTag": "Q4a_1",
        "QuestionType": "DB",
        "Selector": "TB",
        "Configuration": {
          "QuestionDescriptionOption": "UseText"
        },
        "QuestionDescription": "Q4a_1",
        "Validation": {
          "Settings": {
            "ForceResponse": "OFF",
            "Type": "None"
          }
        },
        "Language": [],
        "QuestionID": "QID8",
        "QuestionText_Unsafe": "<p><strong>Imagine you are in the CLSBE cafeteria at lunchtime.</strong></p><p>To simulate a real cafeteria queue, please evaluate each meal option <strong>quickly</strong>. You will have a short countdown (<strong>8 seconds</strong>) next to each rating. Please don't overthink — trust your gut.</p><p>The scale runs from <strong>1 = Not at all appealing</strong> to <strong>7 = Extremely appealing</strong>.</p>"
      }
    },
    {
      "SurveyID": "SV_CLSBECREGROUP03",
      "Element": "SQ",
      "PrimaryAttribute": "QID9",
      "SecondaryAttribute": "",
      "TertiaryAttribute": null,
      "Payload": {
        "QuestionText": "<p><strong>[WARM-UP PLACEHOLDER]</strong></p><p><em>(Warm-up rating — add manually after import using Qualtrics Conjoint module, 1 profile, with timer JS attached.)</em></p><p>Attach <code>javascript/timer-high-pressure.js</code> to the warm-up Conjoint question (high-pressure branch only) and set embedded data <code>warmup_discarded = true</code> on submit.</p>",
        "DataExportTag": "Q4a_warmup_note",
        "QuestionType": "DB",
        "Selector": "TB",
